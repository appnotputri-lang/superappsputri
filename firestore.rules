rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // GLOBALS & HELPERS
    // ---------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'appnotputri@gmail.com' || 
        (userExists() && getUserData().role == 'Super Admin')
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() || 
        (userExists() && getUserData().role == 'Admin')
      );
    }

    function isValidUploadedDocument(data) {
      return data.id is string && data.id.size() <= 128
        && data.projectId is string && data.projectId.size() <= 128
        && data.companyId is string && data.companyId.size() <= 128
        && (!('type' in data) || (data.type is string && (data.type == 'minutes' || data.type == 'deed' || data.type == 'sksp' || data.type == 'custom')))
        && data.title is string && data.title.size() <= 256
        && data.fileName is string && data.fileName.size() <= 256
        && data.mimeType is string && data.mimeType.size() <= 128
        && data.size is number
        && data.driveFileId is string && data.driveFileId.size() <= 128
        && data.driveFolderId is string && data.driveFolderId.size() <= 128
        && data.uploadedBy is string && data.uploadedBy.size() <= 128
        && data.uploadedAt is string && data.uploadedAt.size() <= 128
        && data.createdAt is string && data.createdAt.size() <= 128
        && (!('documentSource' in data) || (data.documentSource is string && (data.documentSource == 'generated' || data.documentSource == 'manual')))
        && (!('documentCategory' in data) || (data.documentCategory is string && (data.documentCategory == 'draft_akta' || data.documentCategory == 'notulen' || data.documentCategory == 'surat_pernyataan' || data.documentCategory == 'scan_akta' || data.documentCategory == 'scan_notulen' || data.documentCategory == 'sksp' || data.documentCategory == 'custom')));
    }

    // ---------------------------------------------------------
    // USER PROFILES
    // ---------------------------------------------------------
    
    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      
      // Super Admin can manage all profiles. 
      // Users can create/update their own profile (but not change their role unless they are Super Admin)
      allow create: if isSignedIn() && (
        (request.auth.uid == uid && request.resource.data.role == 'Staff') ||
        isSuperAdmin()
      );
      
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (request.auth.uid == uid && request.resource.data.role == resource.data.role)
      );
      
      allow delete: if isSuperAdmin();
    }

    // ---------------------------------------------------------
    // PROJECTS & OFFICE PROJECTS
    // ---------------------------------------------------------
    
    match /office_projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();

      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();

      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // ---------------------------------------------------------
    // CLIENT PROFILES (PT/CV)
    // ---------------------------------------------------------
    
    match /profiles/{profileId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /cv_profiles/{id} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // NOTIFICATIONS
    // ---------------------------------------------------------

    match /notifications/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ---------------------------------------------------------
    // SPECIALIZED PROJECT COLLECTIONS
    // ---------------------------------------------------------
    
    match /rupst_projects/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /pendirian_projects/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /rupst_public_projects/{id} {
      allow read: if true; // Publicly accessible
      allow write: if isSuperAdmin();
    }

    match /workflows/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /kbli_saved_records/{id} {
      allow read, write: if isSignedIn();
    }

    match /company_profiles/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /project_uploaded_documents/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(id) && isValidUploadedDocument(request.resource.data) && exists(/databases/$(database)/documents/office_projects/$(request.resource.data.projectId));
      allow update: if isSignedIn() && isValidId(id) && isValidUploadedDocument(request.resource.data) && request.resource.data.projectId == resource.data.projectId;
      allow delete: if isSignedIn();
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

  }
}
