rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // GLOBALS & HELPERS
    // ---------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'appnotputri@gmail.com' || 
        (userExists() && getUserData().role == 'Super Admin')
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() || 
        (userExists() && getUserData().role == 'Admin')
      );
    }

    // ---------------------------------------------------------
    // USER PROFILES
    // ---------------------------------------------------------
    
    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      
      // Super Admin can manage all profiles. 
      // Users can create/update their own profile (but not change their role unless they are Super Admin)
      allow create: if isSignedIn() && (
        (request.auth.uid == uid && request.resource.data.role == 'Staff') ||
        isSuperAdmin()
      );
      
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (request.auth.uid == uid && request.resource.data.role == resource.data.role)
      );
      
      allow delete: if isSuperAdmin();
    }

    // ---------------------------------------------------------
    // PROJECTS & OFFICE PROJECTS
    // ---------------------------------------------------------
    
    match /office_projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();

      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();

      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // ---------------------------------------------------------
    // CLIENT PROFILES (PT/CV)
    // ---------------------------------------------------------
    
    match /profiles/{profileId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /cv_profiles/{id} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // NOTIFICATIONS
    // ---------------------------------------------------------

    match /notifications/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ---------------------------------------------------------
    // SPECIALIZED PROJECT COLLECTIONS
    // ---------------------------------------------------------
    
    match /rupst_projects/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /pendirian_projects/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /rupst_public_projects/{id} {
      allow read: if true; // Publicly accessible
      allow write: if isSuperAdmin();
    }

    match /workflows/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /kbli_saved_records/{id} {
      allow read, write: if isSignedIn();
    }

    match /company_profiles/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

  }
}
