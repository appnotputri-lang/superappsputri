rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedUser() {
      return request.auth != null && request.auth.token.email_verified == true && (
        request.auth.token.email == 'appnotputri@gmail.com' ||
        request.auth.token.email == 'rdyndi@gmail.com' ||
        request.auth.token.email == 'notarisppatputri@gmail.com'
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /profiles/{profileId} {
      allow read, write: if isAllowedUser();
    }

    match /projects/{projectId} {
      allow read, write: if isAllowedUser();
    }

    match /rupst_projects/{rupstId} {
      allow read, write: if isAllowedUser();
    }

    match /pendirian_projects/{pendirianId} {
      allow read, write: if isAllowedUser();
    }
  }
}
