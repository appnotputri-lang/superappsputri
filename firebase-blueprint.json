{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information and role of an application user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Super Admin", "Admin", "Staff"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "CompanyProfile": {
      "title": "Company Profile (Client)",
      "description": "Information about a client company (PT/CV).",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "domicile": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyName"]
    },
    "Project": {
      "title": "Office Project",
      "description": "A workflow instance for a legal document process.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "clientId": { "type": "string" },
        "jobType": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "currentStep": { "type": "string" },
        "assignedTo": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "clientId", "jobType", "status"]
    },
    "Timeline": {
      "title": "Project Timeline",
      "description": "Log entry of project history.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "status": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "status", "title"]
    },
    "Task": {
      "title": "Project Task",
      "description": "Checklist item for a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "completedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "title", "status"]
    },
    "DocumentReference": {
      "title": "Document Reference",
      "description": "Metadata for a document associated with a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "url": { "type": "string" },
        "refId": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "/user_profiles/{uid}": {
      "schema": "UserProfile",
      "description": "User account information and roles."
    },
    "/profiles/{profileId}": {
      "schema": "CompanyProfile",
      "description": "Client company data (PT)."
    },
    "/cv_profiles/{profileId}": {
      "schema": "CompanyProfile",
      "description": "Client company data (CV)."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Main project records."
    },
    "/office_projects/{projectId}": {
      "schema": "Project",
      "description": "Legacy office project records."
    },
    "/projects/{projectId}/timelines/{timelineId}": {
      "schema": "Timeline",
      "description": "History logs for a project."
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Checklist tasks for a project."
    },
    "/projects/{projectId}/documents/{docId}": {
      "schema": "DocumentReference",
      "description": "Document links for a project."
    },
    "/notifications/{notifId}": {
      "schema": "object",
      "description": "System notifications for users."
    },
    "/rupst_projects/{id}": {
      "schema": "CompanyData",
      "description": "RUPST projects."
    },
    "/pendirian_projects/{id}": {
      "schema": "CompanyData",
      "description": "Pendirian projects."
    },
    "/rupst_public_projects/{id}": {
      "schema": "CompanyData",
      "description": "Public RUPST projects."
    }
  }
}
