{
  "entities": {
    "ProjectUploadedDocument": {
      "title": "Project Uploaded Document",
      "description": "Metadata of documents uploaded by users to a specific project Google Drive folder.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "projectId": { "type": "string" },
        "type": { "type": "string", "enum": ["minutes", "deed", "sksp", "custom"] },
        "title": { "type": "string" },
        "fileName": { "type": "string" },
        "mimeType": { "type": "string" },
        "size": { "type": "number" },
        "driveFileId": { "type": "string" },
        "driveFolderId": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "string" },
        "createdAt": { "type": "string" },
        "documentSource": { "type": "string", "enum": ["generated", "manual"] },
        "documentCategory": { "type": "string", "enum": ["draft_akta", "notulen", "surat_pernyataan", "scan_akta", "scan_notulen", "sksp", "custom"] }
      },
      "required": ["id", "companyId", "projectId", "title", "fileName", "mimeType", "size", "driveFileId", "driveFolderId", "uploadedBy", "uploadedAt", "createdAt"]
    }
  },
  "firestore": {
    "/project_uploaded_documents/{documentId}": {
      "schema": "ProjectUploadedDocument",
      "description": "Collection of uploaded documents metadata."
    }
  }
}
