{
  "entities": {
    "notification": {
      "title": "Notification",
      "description": "System-wide notification for project changes, creations, or deletions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "type": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "profile": {
      "title": "Company Profile",
      "description": "Company profile draft for the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" }
      }
    },
    "kbli_item": {
      "title": "KBLI 2025 Item",
      "description": "Details of a KBLI 2025 classification.",
      "type": "object",
      "properties": {
        "kode": { "type": "string" },
        "judul": { "type": "string" },
        "uraian": { "type": "string" },
        "ruang_lingkup": { "type": "string" },
        "tingkat_risiko": { "type": "string" },
        "perizinan_berusaha": { "type": "string" },
        "skala_usaha": { "type": "string" },
        "jangka_waktu": { "type": "string" },
        "kewajiban": { "type": "string" },
        "kewenangan": { "type": "string" },
        "ketentuan_khusus": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "whatsapp_gateway_config": {
      "title": "WhatsApp Gateway Config",
      "description": "Settings for Fonnte WhatsApp API integration",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "nomorAdmin": { "type": "string" },
        "nomorTujuanDefault": { "type": "string" }
      }
    },
    "kbli_saved_record": {
      "title": "Saved KBLI Record",
      "description": "Saved KBLI mappings and suggestions for clients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "type": { "type": "string" },
        "kelompokUsaha": { "type": "string" },
        "selectedItems": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/notification" },
      "description": "System-wide real-time notifications"
    },
    "kbli_saved_records/{recordId}": {
      "schema": { "$ref": "#/entities/kbli_saved_record" },
      "description": "Contains saved KBLI mappings and suggestions based on name"
    },
    "profiles/{profileId}": {
      "schema": { "$ref": "#/entities/profile" },
      "description": "Contains global company profiles"
    },
    "projects/{projectId}": {
      "schema": { "$ref": "#/entities/profile" },
      "description": "Contains project-specific data"
    },
    "rupst_projects/{rupstId}": {
      "schema": { "$ref": "#/entities/profile" },
      "description": "Contains RUPS Tahunan project-specific data"
    },
    "rupst_public_projects/{rupstId}": {
      "schema": { "$ref": "#/entities/profile" },
      "description": "Contains RUPS Tahunan Public project-specific data"
    },
    "pendirian_projects/{pendirianId}": {
      "schema": { "$ref": "#/entities/profile" },
      "description": "Contains RUPS Pendirian project-specific data"
    },
    "kbli_2025/{kbliKode}": {
      "schema": { "$ref": "#/entities/kbli_item" },
      "description": "Contains KBLI 2025 enriched details"
    },
    "settings/{settingsId}": {
      "schema": { "$ref": "#/entities/whatsapp_gateway_config" },
      "description": "Contains system wide configurations such as WhatsApp Gateway integration settings"
    }
  }
}
